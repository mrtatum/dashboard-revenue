# Copy this file to `.env` next to docker-compose.yml and fill in the values
# produced by `python3 tools/get_refresh_token.py`. Do NOT commit the real .env.
#
# Supports both OneDrive Personal and OneDrive for Business.

# Entra (Azure AD) app client ID — from the app you registered in Azure portal.
MS_CLIENT_ID=

# OAuth authority — selects which Microsoft sign-in endpoint is used.
#   * OneDrive for Business → your tenant GUID (e.g. 12345678-aaaa-bbbb-cccc-...)
#                              or domain         (e.g. contoso.onmicrosoft.com)
#   * OneDrive Personal     → consumers
#   * Either                → common
MS_TENANT=

# Long-lived refresh token from tools/get_refresh_token.py.
# Treat this like a password — anyone holding it can read whatever the
# signed-in Microsoft account can read on OneDrive.
MS_REFRESH_TOKEN=

# IDs that scope the container to one folder. Also from get_refresh_token.py.
ONEDRIVE_DRIVE_ID=
ONEDRIVE_ITEM_ID=

# Optional: require `X-Rebuild-Token: <value>` on /rebuild calls.
# Set to any long random string for internet-facing deployments.
REBUILD_TOKEN=

# Run an initial bake on startup if the cached HTML isn't there yet.
BAKE_ON_START=1

# Background auto-refresh — poll OneDrive every N seconds and rebuild only
# when something has actually changed. 0 disables. 300 = every 5 minutes.
# The dashboard tab will then auto-reload the next time it polls /bake_id.
AUTO_REFRESH_INTERVAL_SECONDS=300
