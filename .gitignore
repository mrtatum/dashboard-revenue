Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Local backups ----
*.zip
*_backup_*
Dashboard_Revenue_backup_*

# ---- Customer / business data — NEVER commit ----
# Everything under Sources/ is runtime data pulled from OneDrive
# (xlsx + generated manifest.json/orders.json with real customer info).
/Sources/

# Local working copies of the source spreadsheets and LibreOffice/Excel
# lock files — these contain real customer data and are pulled at runtime.
*.xlsx
.~lock.*#

# The baked dashboard at repo root contains embedded customer data and is
# regenerated by the container at runtime — it's a build artifact.
/Pipeline_Dashboard.html

