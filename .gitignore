# ---- Secrets — NEVER commit these ----
container/.env
container/secrets/
**/refresh_token
**/*.pem
**/*.key

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# ---- Generated / runtime data ----
container/sources/
container/static/
**/last_bake.json

# ---- OS / editor junk ----
